# LexiDraft AI — Environment Variables
# Copy this file to .env.local for local dev, and add these to Vercel Dashboard → Settings → Environment Variables

# ── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase Service Role (server-only, never expose to browser) ────────────
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Vercel Cron Secret (protects /api/cron/cleanup endpoint) ───────────────
# Generate with: openssl rand -hex 32
# Add the same value in Vercel Dashboard → Settings → Environment Variables
CRON_SECRET=your-cron-secret-here

# ── AI (optional — only needed if using real Claude/Gemini generation) ──────
# ANTHROPIC_API_KEY=your-anthropic-key-here
# GOOGLE_AI_API_KEY=your-google-ai-key-here
